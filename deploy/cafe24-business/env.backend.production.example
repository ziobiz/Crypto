# backend/.env (운영)
DATABASE_URL="postgresql://crypto:STRONG_PASSWORD@localhost:5432/crypto_workflow?schema=public"

PORT=4000
NODE_ENV=production

# 프론트 도메인 (쉼표로 복수 가능)
CORS_ORIGIN=https://api.tinpass.com,https://tinpass.com,https://www.tinpass.com

JWT_SECRET=CHANGE_TO_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

UPLOAD_DIR=/var/www/crypto-workflow/uploads

EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/USD
